# =============================================================================
# .env — Variables de entorno para el proyecto GCI
# Copia este archivo como .env y ajusta las rutas a tu máquina.
# IMPORTANTE: .env nunca debe subirse a git (está en .gitignore)
# =============================================================================

#-----------------------------------------------------
# Ruta absoluta al repositorio del portafolio en tu máquina
#-----------------------------------------------------
PORTFOLIO_DIR="/home/ariel/Escritorio/Proyectos Profesionales/1. Presentacion/1. Portafolio/src"

# Subcarpeta dentro del portafolio donde se publicará el sitio Quarto
GCI_SUBFOLDER="gci"


#-----------------------------------------------------
# Rutas del proyecto Quarto (usadas también por los .qmd)
#-----------------------------------------------------
FOLDER_PRJCT="/home/ariel/Escritorio/Proyectos Profesionales/1. Presentacion/2. Proyectos Portafolios/2. Análisis de Indices GCI/"

FOLDER_RAW=${FOLDER_PRJCT}data/raw/
FOLDER_PROCESSED=${FOLDER_PRJCT}data/processed/
FOLDER_TMP=${FOLDER_PRJCT}tmp/

PDF_FILES_PATH=${FOLDER_RAW}pdf/

FIG_FOLDER=${FOLDER_PRJCT}doc/figures/
